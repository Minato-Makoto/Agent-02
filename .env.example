# Agent-02 runtime env example
# Do not commit secrets in this file.

# Local llama.cpp router paths
SERVER_EXE=D:\AI Agent\llama.cpp\llama-server.exe
MODELS_DIR=D:\AI Agent\models

# Gateway settings
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=18789
ALLOW_REMOTE_ADMIN=0
AUTO_OPEN_BROWSER=1
WORKSPACE=workspace
EXTRA_ARGS=

# Optional channel token fallbacks
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
ZALO_BOT_TOKEN=

# Shared inference settings
CTX_SIZE=16384
GPU_LAYERS=-1
THREADS=0
TEMPERATURE=0.1
TOP_P=0.9
TOP_K=40
REPEAT_PENALTY=1.1
SEED=-1
REASONING_EFFORT=
MAX_TOKENS=8192
HOST=127.0.0.1
PORT=8080
BOOT_TIMEOUT=120
HEALTH_TIMEOUT=2
REQUEST_TIMEOUT=300
SHUTDOWN_TIMEOUT=5
COMPAT_RETRY_LIMIT=8
MAX_REQUESTS_PER_MINUTE=0
MAX_ITERATIONS=60
MAX_REPEATS=3
AGENT_TIMEOUT=300

# Browser/Desktop tools
AGENTFORGE_BROWSER_HEADLESS=0
AGENTFORGE_DESKTOP_CONTROL=1

# Tool timeout policy
TOOL_TIMEOUT_BROWSER_NAV_MS=60000
TOOL_TIMEOUT_BROWSER_ACTION_MS=15000
TOOL_TIMEOUT_BROWSER_WAIT_MS=30000
TOOL_TIMEOUT_DESKTOP_ACTION_MS=5000
TOOL_TIMEOUT_DESKTOP_SCREENSHOT_S=15
TOOL_TIMEOUT_WEB_REQUEST_S=30
TOOL_TIMEOUT_WEB_SEARCH_S=15
TOOL_TIMEOUT_PHOTOSHOP_S=30
TOOL_TIMEOUT_PROCESS_LIST_S=10

# Shell policy: 1 = workspace-only default, 0 = allow broader cwd
SHELL_WORKSPACE_ONLY=1
